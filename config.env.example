# DreamMaker — CF WebSocket Edge Fix configuration
# Copy this file to config.env and adjust if needed.
#   cp config.env.example config.env
# All scripts under bin/ and scripts/ source ./config.env automatically.

# --- Server identity -------------------------------------------------------
SERVER_IP="82.115.26.105"
SSH_USER="root"

# --- Domains ---------------------------------------------------------------
DOMAIN="dreammaker-groupsoft.ir"
CDN_SUB="cdn.dreammaker-groupsoft.ir"
ADMIN_EMAIL="admin@dreammaker-groupsoft.ir"

# --- Xray identity ---------------------------------------------------------
# Primary UUID used by all CDN-fronted client links (WSS:2083, gRPC:2053).
UUID="13e8b080-6162-4d51-98e4-67611aa5f7f0"

# Reality key pair (server-side x25519). Public key goes into client links;
# private key stays on the server inside /usr/local/etc/xray/config.json.
PUB_KEY="oBavVYJOvTk1jhyAL6m8yDGCksDA1vhY7q4VyZypkUM"
PRIV_KEY="6H1sXCkdhMzYCyrcFDbkViy92KslvB22zJuVsnC6rWg"

# --- v2.0 multi-protocol identity (DEPLOYMENT-GUIDE-v2 §6) ----------------
# These are the values used by the 5-inbound v2.0 deployment (Reality 443,
# WS+CDN 80, VMess 2052, Trojan 8443, XHTTP 2096). They differ from the
# CF-edge-fix UUID/keys above; both sets coexist intentionally.
V2_UUID="9f05b292-4922-49ff-a939-381de4f8d193"
V2_REALITY_PUB_KEY="WZ3L5tyOq3AUChLrxoi3aXqQzbjYt-gXjtVSWAaArkc"
V2_REALITY_SHORT_ID="5dadd144264d28c4"
V2_REALITY_SNI="digikala.com"
V2_TROJAN_PASSWORD="1111111111"
V2_WS_PATH="/cdn"
V2_VMESS_PATH="/vmess"
V2_XHTTP_PATH="/xhttp"

# --- Inbound topology ------------------------------------------------------
# Backend xray plain WS inbound (nginx upstreams to this).
XRAY_WS_BACKEND_PORT=8880
# Backend xray plain gRPC inbound (nginx upstreams to this, 127.0.0.1 only).
XRAY_GRPC_BACKEND_PORT=50051
GRPC_SERVICE_NAME="dreammaker-grpc"

# --- Public CF-friendly TLS ports -----------------------------------------
WSS_PUBLIC_PORT=2083    # CF-HTTPS group
GRPC_PUBLIC_PORT=2053   # CF-HTTPS group

# --- Paths -----------------------------------------------------------------
XRAY_CONFIG="/usr/local/etc/xray/config.json"
NGINX_AVAILABLE="/etc/nginx/sites-available"
NGINX_ENABLED="/etc/nginx/sites-enabled"
LE_LIVE_DIR="/etc/letsencrypt/live/dreammaker-groupsoft.ir"
CREDENTIALS_FILE="/root/dreammaker-credentials.txt"

# --- Cloudflare API (optional, READ-ONLY) ---------------------------------
# Per policy, this app NEVER modifies Cloudflare settings. The token is only
# used to READ the current zone state for verification. All mutations are
# performed by the operator manually via the dashboard; see
# docs/CLOUDFLARE-MANUAL.md.
# Leave CF_API_TOKEN blank to skip the API read checks entirely.
CF_API_TOKEN=""
CF_ZONE_ID=""

# --- Cloudflare automation modes ------------------------------------------
# The default 'run-all' pipeline only ever READS from Cloudflare. To allow
# write operations you must explicitly opt in with both:
#   1. CF_APPLY_CONFIRM=YES               (gate flag — refuses without)
#   2. one of the following token paths:
#        a) CF_API_TOKEN with sufficient edit scopes for direct apply, OR
#        b) CF_BOOTSTRAP_TOKEN with User:API Tokens:Edit so a child token
#           can be minted, used, and immediately revoked.
#
# Even with these set, only scripts/41-cloudflare-apply.sh and
# scripts/42-cloudflare-mint.sh perform mutations. bin/run-all.sh remains
# strictly read-only.
CF_APPLY_CONFIRM=""
CF_BOOTSTRAP_TOKEN=""

# --- Expected Cloudflare zone state (v2.0 deployment guide, §5) -----------
# These are the values the verifier in scripts/40-cloudflare.sh expects to
# read from the live zone. Mismatches are reported and added to the manual
# checklist. Override here if your deployment intentionally diverges.
CF_EXPECT_WEBSOCKETS="on"
CF_EXPECT_SSL_MODE="full"          # full | strict (full)
CF_EXPECT_MIN_TLS="1.2"
CF_EXPECT_TLS_1_3="on"
CF_EXPECT_ALWAYS_USE_HTTPS="off"   # off — needed for WS on plaintext :80
CF_EXPECT_AUTO_HTTPS_REWRITES="off"
CF_EXPECT_HTTP3="on"
CF_EXPECT_0RTT="on"
CF_EXPECT_CDN_PROXIED="true"
# Apex DNS proxy is intentionally ambiguous — Reality on port 443 wants
# direct, but the rest of the v2.0 setup uses CDN. Set to "any" to skip
# the apex check, "true" to demand proxied, "false" to demand DNS-only.
CF_EXPECT_APEX_PROXIED="any"
